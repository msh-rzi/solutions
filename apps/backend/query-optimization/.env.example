# Local environment template for query-optimization.
# Copy this file to `.env` in this app directory.

APP_HOST=localhost
PORT_QUERY_OPTIMIZATION=3021
# URL-encode special characters in passwords (e.g. @ => %40).
DATABASE_URL_QUERY_OPTIMIZATION=postgresql://postgres:postgres@localhost:5432/query_optimization

# Optional integration test configuration
DATABASE_URL_QUERY_OPTIMIZATION_TEST=postgresql://postgres:postgres@localhost:5432/query_optimization_test
RUN_QUERY_OPTIMIZATION_INTEGRATION_TESTS=false
